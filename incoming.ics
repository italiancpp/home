---
layout: none
permalink: /incoming.ics
---
BEGIN:VCALENDAR
VERSION:2.0
PRODID:Italian C++ Community
CALSCALE:GREGORIAN
NAME:Italian C++ Community Incoming Events
X-WR-CALNAME:Italian C++ Community Incoming Events
BEGIN:VTIMEZONE
TZID:Europe/Rome
LAST-MODIFIED:20201011T015911Z
X-LIC-LOCATION:Europe/Rome
BEGIN:DAYLIGHT
TZNAME:CEST
TZOFFSETFROM:+0100
TZOFFSETTO:+0200
DTSTART:19700329T020000
RRULE:FREQ=YEARLY;BYMONTH=3;BYDAY=-1SU
END:DAYLIGHT
BEGIN:STANDARD
TZNAME:CET
TZOFFSETFROM:+0200
TZOFFSETTO:+0100
DTSTART:19701025T030000
RRULE:FREQ=YEARLY;BYMONTH=10;BYDAY=-1SU
END:STANDARD
END:VTIMEZONE
{%- assign sorted_eventi = site.eventi | sort: "date" -%}
{%- for event in sorted_eventi -%}
{%- if event.date >= site.time -%}
{%- assign date_stamp = event.date | date: "%Y%m%d" -%}
{%- if event.start_time -%}
{%- assign dtstart = date_stamp | append: "T" | append: event.start_time | remove: ":" | append: "00" -%}
{%- else -%}
{%- assign dtstart = date_stamp -%}
{%- endif -%}
{%- if event.end_time -%}
{%- assign dtend = date_stamp | append: "T" | append: event.end_time | remove: ":" | append: "00" -%}
{%- else -%}
{%- assign dtend = date_stamp -%}
{%- endif -%}
BEGIN:VEVENT
DTSTAMP:{{ site.time | date: "%Y%m%dT%H%M%SZ" }}
UID:{{ event.path | slugify }}@italiancpp.org
DTSTART;TZID=Europe/Rome:{{ dtstart }}
DTEND;TZID=Europe/Rome:{{ dtend }}
SUMMARY:{{ event.title | strip_html | strip_newlines }}
URL:{{ event.url | absolute_url }}
DESCRIPTION:{{ event.excerpt | strip_html | strip_newlines }}
{%- if event.location %}
LOCATION:{{ event.location }}
{%- endif %}
END:VEVENT
{%- endif -%}
{%- endfor %}
END:VCALENDAR